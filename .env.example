# Copy this file to swat_forecast/.env and historical_data/.env and fill in real values.

# Database
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_USER=postgres
DATABASE_PASSWORD=
DATABASE_NAME=postgres

# SMTP / Email alerts (swat_forecast only)
SMTP_HOST=mailrelay.uc-workd.com
SMTP_PORT=587
SMTP_USER=noreply@hii.or.th
SMTP_PASS=
ALERT_EMAIL=email1@email.com,email2@email.com

# Data source base URL (swat_forecast only)
HII_BASE_URL=https://tiservice.hii.or.th/water_balance

# Feature flags
# Set to false to skip DB saving (useful for teammates without a local DB)
SWAT_SAVE_DB=true
